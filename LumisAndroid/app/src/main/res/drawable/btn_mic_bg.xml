<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:endColor="#4569F3"
                android:startColor="#4D8AFF" />
            <stroke
                android:width="5dp"
                android:color="#D9E7FF" />
        </shape>
    </item>
    <item android:state_activated="true">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:endColor="#3E62E9"
                android:startColor="#4A87FF" />
            <stroke
                android:width="5dp"
                android:color="#D9E7FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:endColor="#5B8CFF"
                android:startColor="#4D8AFF" />
            <stroke
                android:width="5dp"
                android:color="#E0ECFF" />
        </shape>
    </item>
</selector>
