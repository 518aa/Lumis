<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_warm_gradient"
    android:fillViewport="true"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Lumis Mascot -->
        <ImageView
            android:id="@+id/ivMascot"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/lumis_face_happy"
            android:contentDescription="Lumis"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="Lumis"
            android:textColor="@color/purple"
            android:textSize="38sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintTop_toBottomOf="@id/ivMascot"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="儿童英语语音课堂"
            android:textColor="@color/text_soft"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/tvLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 邮箱输入框 -->
        <TextView
            android:id="@+id/tvEmailLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="📧 邮箱"
            android:textColor="@color/text_mid"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xs"
            android:background="@drawable/bg_login_input"
            android:hint="请输入邮箱地址"
            android:inputType="textEmailAddress"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:textColor="@color/text_main"
            android:textColorHint="@color/text_soft"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tvEmailLabel" />

        <!-- 密码输入框 -->
        <TextView
            android:id="@+id/tvPasswordLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="🔒 密码"
            android:textColor="@color/text_mid"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/etEmail"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xs"
            android:background="@drawable/bg_login_input"
            android:hint="至少6位密码"
            android:inputType="textPassword"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:textColor="@color/text_main"
            android:textColorHint="@color/text_soft"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel" />

        <!-- 昵称输入框（注册时显示） -->
        <TextView
            android:id="@+id/tvUsernameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="😊 昵称"
            android:textColor="@color/text_mid"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/etPassword"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xs"
            android:background="@drawable/bg_login_input"
            android:hint="给自己取个名字吧"
            android:inputType="text"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:textColor="@color/text_main"
            android:textColorHint="@color/text_soft"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvUsernameLabel" />

        <!-- 邀请码（注册时显示，金章样式） -->
        <LinearLayout
            android:id="@+id/inviteCodeContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/etUsername">

            <TextView
                android:id="@+id/tvInviteLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎫 邀请码"
                android:textColor="@color/text_mid"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_xs">

                <EditText
                    android:id="@+id/etInviteCode"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:hint="输入4位邀请码"
                    android:inputType="textCapCharacters"
                    android:maxLength="4"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="80dp"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_soft"
                    android:textSize="16sp"
                    android:letterSpacing="0.3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:background="@drawable/bg_invite_badge"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/spacing_sm"
                    android:text="省99元"
                    android:textColor="@color/text_on_gold"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>

        <!-- 登录/注册按钮 -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="@drawable/btn_purple_gradient"
            android:text="登录"
            android:textColor="@color/text_on_purple"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:elevation="4dp"
            android:stateListAnimator="@null"
            app:layout_constraintTop_toBottomOf="@id/inviteCodeContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="没有账号？点击注册"
            android:textColor="@color/purple"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:indeterminateTint="@color/purple"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvSwitch"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
