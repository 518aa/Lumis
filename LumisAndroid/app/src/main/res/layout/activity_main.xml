<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <!-- Header: 问候 + 进度 -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_sm"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="你好 👋"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 进度胶囊 -->
            <TextView
                android:id="@+id/progressPill"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/progress_pill_height"
                android:background="@drawable/bg_progress_pill"
                android:gravity="center"
                android:paddingHorizontal="@dimen/spacing_md"
                android:text="⭐ 0 星 · 第1课"
                android:textColor="@color/purple"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- 设置按钮 -->
            <ImageView
                android:id="@+id/btnSettings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:src="@drawable/ic_help_space"
                android:padding="4dp"
                android:contentDescription="设置"
                app:tint="@color/text_soft" />
        </LinearLayout>

        <!-- 用户名 -->
        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text=""
            android:textColor="@color/text_mid"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 模式切换 Toggle -->
    <LinearLayout
        android:id="@+id/modeToggle"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/toggle_height"
        android:layout_marginTop="@dimen/spacing_md"
        android:background="@drawable/bg_mode_toggle"
        android:orientation="horizontal"
        android:padding="3dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnModeTeaching"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/bg_mode_toggle_selected"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:text="📚 教学"
            android:textColor="@color/text_on_purple"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnModeGenie"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:text="🎤 跟屁虫"
            android:textColor="@color/text_mid"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Lumis 角色 + 脉冲环 -->
    <FrameLayout
        android:id="@+id/lumisContainer"
        android:layout_width="@dimen/mic_container_size"
        android:layout_height="@dimen/mic_container_size"
        android:layout_marginTop="@dimen/spacing_md"
        app:layout_constraintTop_toBottomOf="@id/modeToggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 脉冲环1 -->
        <View
            android:id="@+id/ripple1"
            android:layout_width="@dimen/mic_button_size"
            android:layout_height="@dimen/mic_button_size"
            android:layout_gravity="center"
            android:background="@drawable/bg_pulse_ring_cream"
            android:alpha="0" />

        <!-- 脉冲环2 -->
        <View
            android:id="@+id/ripple2"
            android:layout_width="@dimen/mic_button_size"
            android:layout_height="@dimen/mic_button_size"
            android:layout_gravity="center"
            android:background="@drawable/bg_pulse_ring_cream"
            android:alpha="0" />

        <!-- Lumis 角色脸 -->
        <ImageView
            android:id="@+id/ivLumisFace"
            android:layout_width="@dimen/lumis_face_size"
            android:layout_height="@dimen/lumis_face_size"
            android:layout_gravity="center"
            android:src="@drawable/lumis_face_idle"
            android:contentDescription="Lumis" />

        <!-- 麦克风按钮（覆盖在角色上） -->
        <ImageButton
            android:id="@+id/btnTalk"
            android:layout_width="@dimen/lumis_face_size"
            android:layout_height="@dimen/lumis_face_size"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            android:src="@android:color/transparent"
            android:contentDescription="开始对话" />

        <!-- 麦克风 glow -->
        <View
            android:id="@+id/micGlow"
            android:layout_width="@dimen/mic_container_size"
            android:layout_height="@dimen/mic_container_size"
            android:layout_gravity="center"
            android:background="@drawable/btn_mic_glow"
            android:alpha="0" />
    </FrameLayout>

    <!-- 状态胶囊 -->
    <LinearLayout
        android:id="@+id/statusPill"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/status_pill_height"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_status_pill"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md"
        app:layout_constraintTop_toBottomOf="@id/lumisContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/statusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/shape_dot_star"
            app:tint="@color/purple" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="点击开始上课"
            android:textColor="@color/text_mid"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 连接跳动圆点 -->
    <LinearLayout
        android:id="@+id/dotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/statusPill"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/dot1"
            android:layout_width="@dimen/dot_size"
            android:layout_height="@dimen/dot_size"
            android:layout_marginEnd="4dp"
            android:background="@drawable/shape_dot_star" />

        <View
            android:id="@+id/dot2"
            android:layout_width="@dimen/dot_size"
            android:layout_height="@dimen/dot_size"
            android:layout_marginEnd="4dp"
            android:background="@drawable/shape_dot_star" />

        <View
            android:id="@+id/dot3"
            android:layout_width="@dimen/dot_size"
            android:layout_height="@dimen/dot_size"
            android:background="@drawable/shape_dot_star" />
    </LinearLayout>

    <!-- 聊天气泡区 -->
    <ScrollView
        android:id="@+id/scrollChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/dotsContainer"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="@dimen/spacing_xs" />
    </ScrollView>

    <!-- 底部按钮栏 -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_bar_height"
        android:background="@drawable/bg_bottom_bar"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_xl"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 历史 -->
        <TextView
            android:id="@+id/btnHistory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📋"
            android:textSize="24sp"
            android:contentDescription="历史" />

        <!-- 麦克风 (中间大按钮) -->
        <TextView
            android:id="@+id/btnMic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🎙️"
            android:textSize="32sp"
            android:contentDescription="麦克风" />

        <!-- 星星 -->
        <TextView
            android:id="@+id/btnStars"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⭐"
            android:textSize="24sp"
            android:contentDescription="星星" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
