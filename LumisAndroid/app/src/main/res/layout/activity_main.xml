<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_lumis_screen">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="@dimen/screen_side_padding"
        android:paddingTop="@dimen/screen_top_padding"
        android:paddingEnd="@dimen/screen_side_padding"
        android:paddingBottom="@dimen/screen_bottom_padding">

        <LinearLayout
            android:id="@+id/headerBar"
            android:layout_width="0dp"
            android:layout_height="@dimen/header_height"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="@dimen/content_max_width">

            <ImageView
                android:layout_width="@dimen/logo_icon_size"
                android:layout_height="@dimen/logo_icon_size"
                android:contentDescription="@null"
                android:src="@drawable/ic_lumis_star_outline" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:gravity="center_vertical"
                android:singleLine="true"
                android:text="Lumis"
                android:textColor="#071B4F"
                android:textSize="23sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="@dimen/top_coin_width"
                android:layout_height="36dp"
                android:background="@drawable/bg_top_pill"
                android:elevation="5dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <FrameLayout
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    android:background="@drawable/bg_coin_circle">

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_star_white" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvStarCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="320"
                    android:textColor="#071B4F"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:gravity="center_vertical"
                android:maxWidth="@dimen/greeting_max_width"
                android:singleLine="true"
                android:text="Hi, Amy"
                android:textColor="#071B4F"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnAbout"
                android:layout_width="@dimen/top_avatar_size"
                android:layout_height="@dimen/top_avatar_size"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_hint_card"
                android:contentDescription="关于 Lumis"
                android:elevation="5dp"
                android:padding="7dp"
                android:src="@drawable/ic_lightbulb" />
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lessonCard"
            android:layout_width="0dp"
            android:layout_height="@dimen/lesson_card_height"
            android:layout_marginTop="@dimen/main_vertical_gap"
            android:background="@drawable/bg_lumis_card"
            android:elevation="7dp"
            android:padding="@dimen/lesson_card_padding"
            app:layout_constraintEnd_toEndOf="@id/headerBar"
            app:layout_constraintStart_toStartOf="@id/headerBar"
            app:layout_constraintTop_toBottomOf="@id/headerBar">

            <ImageView
                android:id="@+id/imgLesson"
                android:layout_width="@dimen/lesson_image_width"
                android:layout_height="@dimen/lesson_image_height"
                android:background="@drawable/bg_lesson_image"
                android:clipToOutline="true"
                android:contentDescription="@null"
                android:elevation="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/lumis_girl"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvLessonIndex"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/lesson_content_gap"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="Lesson 3"
                android:textColor="#176BFF"
                android:textSize="14sp"
                app:layout_constraintStart_toEndOf="@id/imgLesson"
                app:layout_constraintTop_toTopOf="@id/imgLesson" />

            <TextView
                android:id="@+id/tvLessonTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="At School"
                android:textColor="#071B4F"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/imgSchool"
                app:layout_constraintStart_toStartOf="@id/tvLessonIndex"
                app:layout_constraintTop_toBottomOf="@id/tvLessonIndex" />

            <TextView
                android:id="@+id/tvLessonSub"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="学习在学校场景中常用的英语表达"
                android:textColor="#6A7790"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/imgSchool"
                app:layout_constraintStart_toStartOf="@id/tvLessonIndex"
                app:layout_constraintTop_toBottomOf="@id/tvLessonTitle" />

            <View
                android:id="@+id/progressTrack"
                android:layout_width="@dimen/progress_track_width"
                android:layout_height="9dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_progress_track"
                app:layout_constraintStart_toStartOf="@id/tvLessonIndex"
                app:layout_constraintTop_toBottomOf="@id/tvLessonSub" />

            <View
                android:layout_width="@dimen/progress_fill_width"
                android:layout_height="9dp"
                android:background="@drawable/bg_progress_fill"
                app:layout_constraintBottom_toBottomOf="@id/progressTrack"
                app:layout_constraintStart_toStartOf="@id/progressTrack"
                app:layout_constraintTop_toTopOf="@id/progressTrack" />

            <TextView
                android:id="@+id/tvProgressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="sans-serif-medium"
                android:text="6 / 12"
                android:textColor="#23345D"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@id/progressTrack"
                app:layout_constraintStart_toEndOf="@id/progressTrack"
                app:layout_constraintTop_toTopOf="@id/progressTrack" />

            <ImageView
                android:id="@+id/imgSchool"
                android:layout_width="@dimen/lesson_art_size"
                android:layout_height="@dimen/lesson_art_size"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/lumis_school"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:id="@+id/practicePanel"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/main_vertical_gap"
            android:layout_marginBottom="@dimen/main_vertical_gap"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintBottom_toTopOf="@id/chatPanel"
            app:layout_constraintEnd_toEndOf="@id/headerBar"
            app:layout_constraintStart_toStartOf="@id/headerBar"
            app:layout_constraintTop_toBottomOf="@id/lessonCard">

            <ImageView
                android:id="@+id/imgRobot"
                android:layout_width="@dimen/practice_robot_width"
                android:layout_height="@dimen/practice_robot_height"
                android:layout_gravity="bottom|start"
                android:alpha="0.86"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/lumis_robot" />

            <FrameLayout
                android:id="@+id/micContainer"
                android:layout_width="@dimen/mic_container_size"
                android:layout_height="@dimen/mic_container_size"
                android:layout_gravity="center"
                android:clipChildren="false"
                android:clipToPadding="false">

                <View
                    android:id="@+id/micGlow"
                    android:layout_width="@dimen/mic_container_size"
                    android:layout_height="@dimen/mic_container_size"
                    android:layout_gravity="center"
                    android:alpha="0.45"
                    android:background="@drawable/btn_mic_glow" />

                <View
                    android:id="@+id/ripple1"
                    android:layout_width="@dimen/mic_button_size"
                    android:layout_height="@dimen/mic_button_size"
                    android:layout_gravity="center"
                    android:alpha="0"
                    android:background="@drawable/bg_mic_ripple_ring" />

                <View
                    android:id="@+id/ripple2"
                    android:layout_width="@dimen/mic_button_size"
                    android:layout_height="@dimen/mic_button_size"
                    android:layout_gravity="center"
                    android:alpha="0"
                    android:background="@drawable/bg_mic_ripple_ring" />

                <ImageButton
                    android:id="@+id/btnTalk"
                    android:layout_width="@dimen/mic_button_size"
                    android:layout_height="@dimen/mic_button_size"
                    android:layout_gravity="center"
                    android:background="@drawable/btn_mic_bg"
                    android:contentDescription="开始口语练习"
                    android:elevation="12dp"
                    android:padding="@dimen/mic_icon_padding"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_mic_space" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/dotsContainer"
                android:layout_width="72dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="22dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <View
                    android:id="@+id/dot1"
                    android:layout_width="8dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_voice_bar" />

                <View
                    android:id="@+id/dot2"
                    android:layout_width="8dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_voice_bar" />

                <View
                    android:id="@+id/dot3"
                    android:layout_width="8dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_voice_bar" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="点击麦克风 开始说话"
                android:textColor="#176BFF"
                android:textSize="15sp" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/chatPanel"
            android:layout_width="0dp"
            android:layout_height="@dimen/main_chat_panel_height"
            android:background="@drawable/bg_lumis_card"
            android:elevation="6dp"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/headerBar"
            app:layout_constraintStart_toStartOf="@id/headerBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/bg_circle_soft_blue"
                    android:contentDescription="@null"
                    android:padding="4dp"
                    android:src="@drawable/ic_robot_face" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center_vertical"
                    android:text="Lumi 老师"
                    android:textColor="#071B4F"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/scrollChat"
                android:layout_width="match_parent"
                android:layout_height="@dimen/chat_live_height"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chat_live"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="never">

                <TextView
                    android:id="@+id/tvChat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="5dp"
                    android:padding="12dp"
                    android:textColor="#26375F"
                    android:textSize="13sp" />
            </ScrollView>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
