<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero 区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_about_hero"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_xl"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_lg"
            android:gravity="center_horizontal">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/lumis_face_happy"
                android:contentDescription="Lumis" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="LUMIS"
                android:textColor="@color/gold"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center"
                android:text="一个父亲，用代码为女儿造的数字英语老师"
                android:textColor="#B5B0CC"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- 🌱 缘起 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="1dp"
                app:strokeColor="#F0EBF7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌱 缘起"
                        android:textColor="@color/purple"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="yingyujinjie、lumis-api、lunis-api、learning-adventure、task-research-english——五个项目目录，五次推翻重来，横跨三个月。如果有人翻看这些代码仓库的 git log，他会看到一个父亲从焦虑到执拗、从执拗到疯狂、从疯狂到顿悟的完整弧线。"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="一切的起点，是一个朴素的念头：我的孩子，能不能真正学会说英语？不是那种考试能拿90分但张嘴就哑的英语。是那种碰到一个外国小朋友，能自然地说「Hi! I&#x2019;m Lili! Do you want to play with me?」的英语。"
                        android:textColor="@color/coral"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🧱 拆掉那堵墙 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="1dp"
                app:strokeColor="#F0EBF7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧱 拆掉那堵看不见的墙"
                        android:textColor="@color/purple"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="人教PEP版：一节课40分钟，一周两到三节，班上40个孩子。老师问「What&#x2019;s your name?」，每个孩子轮到开口说一句的时间，不到30秒。一周的总开口时长，加起来可能不超过3分钟。"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="校外培训：一年两万起步的外教课，一周一次，每次25分钟。钱花了，时间花了，孩子依然张不开嘴。"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="这是一堵墙。一堵课程大纲、教学法、班级规模三重锁死的墙。传统路径翻不过去。那就绕过去。"
                        android:textColor="@color/coral"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🔄 五次推倒重来 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="1dp"
                app:strokeColor="#F0EBF7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔄 五次推倒重来"
                        android:textColor="@color/purple"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="第一次：一口气设计了120课的完整课程体系。做完了才发现——这不是课程，这是负担。推倒。\n\n第二次：按「能力级别」组织。进步很大，但产品形态还是API服务。推倒。\n\n第三次：接入了智能体平台，做了AI Bot。产品形态找到了，但限制太多。推倒。\n\n第四次：做了三科合一的综合学习平台。技术栈最漂亮的一次，但大而全不是他要的东西。推倒。"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="第五次，他找到了正确的载体——LUMIS AI语音助手。这一次他只做了两件事——但做到了极致。"
                        android:textColor="@color/coral"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 📚 LUMIS 教学 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="1dp"
                app:strokeColor="#F0EBF7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📚 LUMIS 教学"
                        android:textColor="@color/purple"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="打开App，对着LUMIS说「开始上课」。Lumis会用孩子的名字打招呼，然后进入精心设计的四轮10分钟教学："
                        android:textColor="@color/text_mid"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="第0轮（1分钟）问候与热身\n第1轮（3分钟）新词领读\n第2轮（2分钟）互动与纠错\n第3轮（1分钟）总结与期待"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="Lumis永远不会说「错了」。如果孩子把「dog」说成了「dag」，Lumis会说「Yes! Dog! D-O-G! Dog!」——用「回声法」把正确的发音轻轻递回去。这不是教学法，这是心理学。"
                        android:textColor="@color/coral"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🎯 120课课程体系 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="1dp"
                app:strokeColor="#F0EBF7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯 120课，6大阶段"
                        android:textColor="@color/purple"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <!-- 紧凑的阶段行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:background="@drawable/bg_stage_row"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 第一阶段 1-20课"
                            android:textColor="@color/purple"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="打招呼、数字1-10、颜色"
                            android:textColor="@color/text_soft"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:background="@drawable/bg_stage_row"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 第二阶段 21-40课"
                            android:textColor="@color/purple"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="26个字母 A-Z 的自然发音"
                            android:textColor="@color/text_soft"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:background="@drawable/bg_stage_row"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 第三阶段 41-60课"
                            android:textColor="@color/purple"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="家庭成员、身体部位、食物、动物"
                            android:textColor="@color/text_soft"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:background="@drawable/bg_stage_row"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 第四阶段 61-80课"
                            android:textColor="@color/purple"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5大核心句型：This is / I like / What is this / I want / How many"
                            android:textColor="@color/text_soft"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:background="@drawable/bg_stage_row"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 第五阶段 81-100课"
                            android:textColor="@color/purple"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="一天的时光、天气季节、学校生活、生日派对"
                            android:textColor="@color/text_soft"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:background="@drawable/bg_stage_row"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 第六阶段 101-120课"
                            android:textColor="@color/purple"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="故事听说、角色扮演（餐厅点餐、看医生）、毕业"
                            android:textColor="@color/text_soft"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="每天10分钟，一周5天，24周（约半年）走完120课。"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🎤 跟屁虫模式 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="1dp"
                app:strokeColor="#F0EBF7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎤 跟屁虫模式"
                        android:textColor="@color/mint_dark"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="吃饭时，孩子说「我要吃苹果」。Lumis立刻跟上：「I want apple!」孩子说「这个好好吃」。Lumis说：「This is yummy!」"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="没有解释，没有教学，没有纠正。只有翻译。像一个影子一样，孩子说什么，它就用英语复述一遍。"
                        android:textColor="@color/mint_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="激活方式：对着LUMIS说「跟屁虫」。切回教学模式：说「Lumis」。"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 💡 使用指南 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="1dp"
                app:strokeColor="#F0EBF7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 使用指南"
                        android:textColor="@color/purple"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="开始上课：说「开始上课」或「Lumis」\n跟屁虫：说「跟屁虫」\n查看进度：说「我学到第几课了」\n跳课：说「我要学第X课」\n改名字：说「把我的名字改成XX」"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="每日节奏：固定时段10分钟教学 + 吃饭玩耍时开启跟屁虫模式。长按顶部标题栏可退出登录。"
                        android:textColor="@color/text_soft"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 结尾渐变卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/purple">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_closing_gradient"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💌 这不是一个产品"
                        android:textColor="@color/gold"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="他不是在做创业项目，不是在追赶AI教育的风口。他是一个父亲，他看到了传统英语教育的系统性缺陷——整个体系的设计就注定了大多数孩子学完十年英语依然张不开嘴。"
                        android:textColor="#D0C8E8"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="5dp"
                        android:text="10分钟。少刷两个短视频的时间。但如果你坚持半年，你的孩子会拥有一项中国大多数成年人都不具备的能力——自然地、不恐惧地、带着享受地用英语交流。"
                        android:textColor="@color/gold_light"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center"
                        android:lineSpacingExtra="5dp"
                        android:text="Lumis — 一个父亲能给孩子最好的礼物，\n不是恐惧学习的阴影，\n而是开口说话的勇气。"
                        android:textColor="@color/gold"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 版本号 -->
            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_md"
                android:textColor="@color/text_soft"
                android:textSize="12sp" />

            <!-- 火炬计划按钮 -->
            <LinearLayout
                android:id="@+id/btnTorchPlan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="@dimen/spacing_lg"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_gold"
                android:clickable="true"
                android:focusable="true"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 火炬计划（合伙人）"
                    android:textColor="@color/text_on_gold"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 分享按钮 -->
            <LinearLayout
                android:id="@+id/btnShare"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_xl"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_user_card"
                android:clickable="true"
                android:focusable="true"
                android:elevation="1dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_share"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="分享给朋友"
                    android:textColor="@color/purple"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
